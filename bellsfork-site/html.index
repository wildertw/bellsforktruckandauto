  <!-- ==============================
       LOCAL BUSINESS SCHEMA (JSON-LD)
       Notes:
       - Keep NAP consistent across site, Google Business Profile, directories.
       - Replace placeholders like hours, geo, socials with real values.
       ============================== -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
