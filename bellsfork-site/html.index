                  <ul class="mb-0">
                    <li>Greenville, NC</li>
                    <li>Winterville, NC</li>
                    <li>Ayden, NC</li>
                    <li>Farmville, NC</li>
                  </ul>
                </div>
              </div>
              <div class="col-sm-6">
                <div class="p-3 rounded-4 border h-100">
                  <h3 class="h6 fw-bold mb-2">Also Serving</h3>
                  <ul class="mb-0">
                    <li>Grifton, NC</li>
                    <li>Bethel, NC</li>
                    <li>Washington, NC</li>
                    <li>And surrounding areas</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="mt-4">
              <a class="btn btn-accent fw-semibold" href="#contact">Get Directions</a>
              <a class="btn btn-link link-dark fw-semibold" href="#appointment">Request an Appointment</a>
            </div>
          </div>

          <div class="col-lg-5">
            <div class="card shadow-soft border-0">
              <img src="assets/map-area.jpg" width="1000" height="700"
                   class="img-fluid rounded-4"
                   alt="Service area map for Greenville North Carolina and surrounding towns" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==============================
         APPOINTMENT / CONTACT FORM
         Technical: required fields + validation-friendly attributes.
         ============================== -->
    <section id="appointment" class="section-pad bg-light">
      <div class="container">
        <div class="row g-4">
          <div class="col-lg-6">
            <h2 class="display-6 fw-bold">Request Service</h2>
            <p class="text-secondary">
              Tell us about your vehicle and the issue. We’ll confirm availability, next steps, and a recommended inspection/diagnostic path.
            </p>

            <form action="/api/appointment" method="post" class="needs-validation" novalidate aria-label="Appointment request form">
              <!-- Name -->
              <div class="mb-3">
                <label for="fullName" class="form-label fw-semibold">Full Name</label>
                <input type="text" class="form-control" id="fullName" name="fullName" autocomplete="name"
                       required minlength="2" placeholder="Your name">
                <div class="invalid-feedback">Please enter your name.</div>
              </div>

              <!-- Phone -->
              <div class="mb-3">
                <label for="phone" class="form-label fw-semibold">Phone</label>
                <input type="tel" class="form-control" id="phone" name="phone" autocomplete="tel"
                       required pattern="^\(?\d{3}\)?[-.\s]?\d{3}[-.\s]?\d{4}$"
                       placeholder="252-555-1234" aria-describedby="phoneHelp">
                <div id="phoneHelp" class="form-text">Use a 10-digit US phone number.</div>
                <div class="invalid-feedback">Please enter a valid phone number.</div>
              </div>

              <!-- Email -->
              <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Email (optional)</label>
                <input type="email" class="form-control" id="email" name="email" autocomplete="email"
                       placeholder="you@example.com">
              </div>

              <!-- Vehicle -->
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="vehicleYear" class="form-label fw-semibold">Vehicle Year</label>
                  <input type="number" class="form-control" id="vehicleYear" name="vehicleYear"
                         min="1980" max="2035" required placeholder="2018">
                  <div class="invalid-feedback">Enter a valid year.</div>
                </div>
                <div class="col-md-6">
                  <label for="vehicleType" class="form-label fw-semibold">Vehicle Type</label>
                  <select class="form-select" id="vehicleType" name="vehicleType" required>
                    <option value="" selected disabled>Select one</option>
                    <option>Car</option>
                    <option>Truck</option>
                    <option>SUV</option>
                    <option>Diesel</option>
                    <option>Work / Fleet Vehicle</option>
                  </select>
                  <div class="invalid-feedback">Please select a vehicle type.</div>
                </div>
              </div>

              <div class="mb-3 mt-3">
                <label for="serviceNeeded" class="form-label fw-semibold">Service Needed</label>
                <select class="form-select" id="serviceNeeded" name="serviceNeeded" required>
                  <option value="" selected disabled>Select service category</option>
                  <option>Diagnostics (Check Engine / Electrical)</option>
                  <option>Maintenance (Oil Change / Fluids)</option>
                  <option>Brakes</option>
                  <option>Engine / Drivetrain</option>
                  <option>Suspension / Steering</option>
                  <option>Cooling System</option>
                  <option>Other</option>
                </select>
                <div class="invalid-feedback">Please choose a service category.</div>
              </div>

              <div class="mb-3">
                <label for="details" class="form-label fw-semibold">What’s going on?</label>
                <textarea class="form-control" id="details" name="details" rows="4"
                          required minlength="10"
                          placeholder="Describe symptoms, warning lights, noises, when it happens, etc."></textarea>
                <div class="invalid-feedback">Please add a short description (10+ characters).</div>
              </div>

              <div class="row g-3">
                <div class="col-md-6">
                  <label for="preferredDate" class="form-label fw-semibold">Preferred Date</label>
                  <input type="date" class="form-control" id="preferredDate" name="preferredDate" required>
                  <div class="invalid-feedback">Please select a date.</div>
                </div>
                <div class="col-md-6">
                  <label for="preferredTime" class="form-label fw-semibold">Preferred Time</label>
                  <select class="form-select" id="preferredTime" name="preferredTime" required>
                    <option value="" selected disabled>Select a time window</option>
                    <option>8:00 AM – 10:00 AM</option>
                    <option>10:00 AM – 12:00 PM</option>
                    <option>12:00 PM – 2:00 PM</option>
                    <option>2:00 PM – 4:00 PM</option>
                    <option>4:00 PM – 5:30 PM</option>
                  </select>
                  <div class="invalid-feedback">Please select a time window.</div>
                </div>
              </div>

              <div class="form-check mt-3">
                <input class="form-check-input" type="checkbox" value="yes" id="consent" name="consent" required>
                <label class="form-check-label" for="consent">
                  I agree to be contacted about this request.
                </label>
                <div class="invalid-feedback">Consent is required to submit.</div>
              </div>

              <button type="submit" class="btn btn-accent btn-lg fw-semibold mt-3">Submit Request</button>

              <!-- SEO/Trust microcopy -->
              <p class="small-muted mt-3 mb-0">
                Prefer calling? Dial <a href="tel:+12524960005">(252) 496-0005</a> for the quickest scheduling in Greenville, NC.
              </p>
            </form>
          </div>

          <!-- Contact + Map -->
          <div class="col-lg-6" id="contact">
            <div class="card shadow-soft border-0 h-100">
              <div class="card-body p-4">
                <h2 class="h3 fw-bold mb-2">Visit &amp; Contact</h2>
                <p class="text-secondary mb-4">
                  Conveniently located in Greenville, NC. Call for urgent issues or to confirm diesel/truck service availability.
                </p>

                <div class="row g-3">
                  <div class="col-sm-6">
                    <div class="p-3 rounded-4 border h-100">
                      <h3 class="h6 fw-bold mb-1">Phone</h3>
                      <a class="text-decoration-none" href="tel:+12524960005">(252) 496-0005</a>
                    </div>
                  </div>
                  <div class="col-sm-6">
                    <div class="p-3 rounded-4 border h-100">
                      <h3 class="h6 fw-bold mb-1">Address</h3>
                      <div>3840 Charles Blvd<br>Greenville, NC 27858</div>
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="p-3 rounded-4 border">
                      <h3 class="h6 fw-bold mb-1">Hours</h3>
                      <div class="text-secondary">Mon–Fri 8:00 AM–5:30 PM</div>
                      <div class="small-muted">Update these hours to match your real schedule.</div>
                    </div>
                  </div>
                </div>

                <!-- Embedded map placeholder -->
                <div class="mt-4">
                  <h3 class="h6 fw-bold mb-2">Map</h3>
                  <!-- Replace the iframe src with your Google Maps embed link -->
                  <div class="ratio ratio-16x9 rounded-4 overflow-hidden border" aria-label="Map showing Bells Fork Auto and Truck location">
                    <iframe
                      title="Bells Fork Auto and Truck map"
                      src="about:blank"
                      loading="lazy"
                      referrerpolicy="no-referrer-when-downgrade"></iframe>
                  </div>
                  <p class="small-muted mt-2 mb-0">
                    Tip: Use a real Google Maps embed for higher engagement and easier directions.
                  </p>
                </div>

                <hr class="my-4">

                <!-- Emergency CTA -->
                <div class="d-flex flex-column flex-sm-row gap-2">
                  <a class="btn btn-outline-dark" href="tel:+12524960005" aria-label="Call Bells Fork Auto and Truck now">Emergency / Call Now</a>
                  <a class="btn btn-accent fw-semibold" href="#appointment">Schedule Service</a>
                </div>

              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==============================
         FAQ (On-page)
         ============================== -->
    <section id="faq" class="section-pad">
      <div class="container">
        <h2 class="display-6 fw-bold">Frequently Asked Questions</h2>
        <p class="text-secondary mb-4">Quick answers for Greenville, NC drivers. (Also marked up in schema for SEO.)</p>

        <div class="accordion" id="faqAccordion">
          <div class="accordion-item">
            <h3 class="accordion-header" id="faq1">
              <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faqCollapse1"
                      aria-expanded="true" aria-controls="faqCollapse1">
                Do you work on both cars and trucks?
              </button>
            </h3>
            <div id="faqCollapse1" class="accordion-collapse collapse show" aria-labelledby="faq1" data-bs-parent="#faqAccordion">
              <div class="accordion-body text-secondary">
                Yes—cars, light trucks, and many work vehicles. For diesel or specialty needs, call first so we can confirm availability.
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h3 class="accordion-header" id="faq2">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqCollapse2"
                      aria-expanded="false" aria-controls="faqCollapse2">
                What should I do if my check engine light comes on?
              </button>
            </h3>
            <div id="faqCollapse2" class="accordion-collapse collapse" aria-labelledby="faq2" data-bs-parent="#faqAccordion">
              <div class="accordion-body text-secondary">
                If the light is flashing or the vehicle runs rough, stop driving if safe and call us. Otherwise, schedule diagnostics so we can read codes and test the underlying cause.
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h3 class="accordion-header" id="faq3">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqCollapse3"
                      aria-expanded="false" aria-controls="faqCollapse3">
                How do estimates work?
              </button>
            </h3>
            <div id="faqCollapse3" class="accordion-collapse collapse" aria-labelledby="faq3" data-bs-parent="#faqAccordion">
              <div class="accordion-body text-secondary">
                We start with an inspection or diagnostic as needed, explain what we find, and provide clear options. You stay in control of the decision.
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

