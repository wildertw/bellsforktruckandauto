        "url": "https://bellsforkautoandtruck.com/",
        "telephone": "+1-252-496-0005",
        "image": "https://bellsforkautoandtruck.com/assets/logo.png",
        "description": "Local auto repair and truck service in Greenville, NC including diagnostics, maintenance, and repair for cars, trucks, and diesel vehicles.",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "3840 Charles Blvd",
          "addressLocality": "Greenville",
          "addressRegion": "NC",
          "postalCode": "27858",
          "addressCountry": "US"
        },
        "areaServed": [
          "Greenville, NC",
          "Winterville, NC",
          "Ayden, NC",
          "Farmville, NC",
          "Grifton, NC",
          "Bethel, NC",
          "Washington, NC"
        ],
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
            "opens": "08:00",
            "closes": "17:30"
          }
        ],
        "sameAs": [
          "https://www.facebook.com/people/Bells-Fork-Truck-Auto/61585590120772/"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://bellsforkautoandtruck.com/#website",
        "url": "https://bellsforkautoandtruck.com/",
        "name": "Bells Fork Auto & Truck",
        "inLanguage": "en-US"
      },
      {
        "@type": "FAQPage",
        "@id": "https://bellsforkautoandtruck.com/#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Do you work on both cars and trucks?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. We service most makes and models of cars, light trucks, and many diesel vehicles. If you have a specialty request, call and we’ll confirm fit and availability."
            }
          },
          {
            "@type": "Question",
            "name": "How do I schedule an appointment?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Use the appointment request form on this page or call. We’ll confirm your time, collect vehicle details, and provide next steps."
            }
          },
          {
            "@type": "Question",
            "name": "Do you offer emergency or same-day service?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "When availability allows, we prioritize urgent diagnostics and safety concerns. Call first so we can advise the fastest option."
            }
          }
        ]
      }
    ]
  }
  </script>

  <!-- ==============================
       BASIC STYLES
       - Keep CSS lightweight for speed.
       - Ensure strong contrast for accessibility.
       ============================== -->
  <style>
    :root{
      --brand-dark:#0b1220;
      --brand-accent:#f4b400; /* warm accent */
      --brand-muted:#6c757d;
    }
    body{ scroll-behavior:smooth; }
    .bg-brand-dark{ background:var(--brand-dark); }
    .text-accent{ color:var(--brand-accent) !important; }
    .btn-accent{
      background:var(--brand-accent);
      color:#111;
      border:1px solid rgba(0,0,0,.08);
    }
    .btn-accent:hover{ filter:brightness(0.95); }
    .skip-link{
      position:absolute; left:-999px; top:auto; width:1px; height:1px; overflow:hidden;
    }
    .skip-link:focus{
      position:static; width:auto; height:auto; padding:.5rem .75rem; background:#fff; border-radius:.5rem;
      display:inline-block; margin:.5rem;
    }
    .hero{
      background: linear-gradient(180deg, rgba(11,18,32,1) 0%, rgba(11,18,32,0.92) 55%, rgba(11,18,32,1) 100%),
                  url("assets/hero-garage.jpg");
      background-size:cover;
      background-position:center;
    }
    .icon-badge{
      width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;
      background:rgba(244,180,0,.12); border:1px solid rgba(244,180,0,.25);
      flex: 0 0 auto;
    }
    .card{ border-radius:1rem; }
    .shadow-soft{ box-shadow:0 12px 30px rgba(0,0,0,.08); }
    .section-pad{ padding:4rem 0; }
    .small-muted{ color:var(--brand-muted); font-size:.95rem; }
    .list-check li{ margin-bottom:.5rem; }
    .list-check li::marker{ content:"✓  "; color:var(--brand-accent); font-weight:700; }
    footer a{ color:rgba(255,255,255,.85); }
    footer a:hover{ color:#fff; }
  </style>
</head>

