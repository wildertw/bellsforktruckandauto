{
  "name": "bellsfork-site",
  "version": "1.0.0",
  "description": "Bells Fork Truck & Auto - site tooling",
  "scripts": {
    "lint": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,css,html,md}\"",
    "build:js": "esbuild assets/js/utils.js inventory-loader.js vehicle-manager.js --bundle --minify --outdir=assets/js/dist",
    "build:css": "cleancss -o style.min.css style.css",
    "build:vdp": "node generate-vdp.js",
    "build:categories": "node generate-category-pages.js",
    "build:forms": "node generate-form-pages.js",
    "build:homepage": "node prerender-homepage.js",
    "build:inventory": "node prerender-inventory.js",
    "watch:vdp": "node watch-vdp.js",
    "build": "node optimize-images.js && npm run build:js && npm run build:css && npm run build:vdp && npm run build:categories && npm run build:forms && npm run build:homepage && npm run build:inventory"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.0"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "esbuild": "^0.27.3",
    "eslint": "^8.0.0",
    "prettier": "^2.0.0",
    "sharp": "^0.34.5"
  }
}
